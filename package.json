{
  "name": "scopify",
  "version": "1.0.5",
  "private": true,
  "author": {
    "name": "Momo",
    "email": "shuhengwen@gmail.com"
  },
  "contributors": [
    {
      "name": "TrimiTroll",
      "email": "1740627301@qq.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MT-SUPER-POWER/Scopify.git"
  },
  "type": "module",
  "main": "out/main/main.js",
  "description": "Electron + Next.js Music Player Base on NetEase Music API",
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check --write .",
    "i18n:types": "bun script/generate-i18n-types.ts",
    "i18n:audit": "bun script/audit-i18n.ts",
    "electron:install": "bun script/ensure-electron.ts",
    "postinstall": "bun run electron:install",
    "dev": "bun run electron:install && bun run build:web && cross-env ELECTRON_RENDERER_MODE=static bunx electron-vite dev",
    "start": "bunx serve renderer -p 4545",
    "dev:backend": "bun run backend/api-enhanced/app.js",
    "dev:web": "bun run script/dev-web.ts",
    "dev:full": "concurrently -n \"NEXT,NETEASE\" -c \"yellow,red\" --kill-others \"bun run dev:web\" \"bun run dev:backend\"",
    "build:web": "next build",
    "build:electron": "electron-vite build",
    "build:win": "bun run build:web && bun run build:electron && electron-builder -- win",
    "build:mac": "bun run build:web && bun run build:electron && electron-builder -- mac"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "electron-log": "^5.4.4",
    "electron-serve": "^3.0.1",
    "electron-updater": "^6.8.9",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@applemusic-like-lyrics/core": "^0.2.0",
    "@applemusic-like-lyrics/lyric": "^0.3.0",
    "@applemusic-like-lyrics/react": "^0.2.0",
    "@biomejs/biome": "^2.5.0",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/bun": "latest",
    "@types/colorthief": "^2.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-split-pane": "^0.1.67",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colorthief": "^3.3.1",
    "concurrently": "^9.2.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "framer-motion": "^12.40.0",
    "jss": "^10.10.0",
    "jss-preset-default": "^10.10.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.40.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "picocolors": "1.1.1",
    "radix-ui": "^1.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.11.2",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "zustand": "^5.0.14",
    "zustand-devtools": "^1.1.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "build": {
    "appId": "com.momo.scopify",
    "productName": "Scopify",
    "publish": [
      "github"
    ],
    "artifactName": "${productName}.Setup.v${version}.${platform}.${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "compression": "maximum",
    "extraResources": [
      {
        "from": "config",
        "to": "config",
        "filter": [
          "**/*.yml"
        ]
      },
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "out/main/**/*.js",
      "out/types/**/*.js",
      "renderer/**/*",
      "public/**/*",
      "package.json",
      "!**/node_modules",
      "!**/*.map",
      "!backend/api-enhanced"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        "zip",
        "dmg"
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.music",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "trustedDependencies": [
    "electron",
    "electron-builder",
    "sharp",
    "unrs-resolver"
  ]
}
