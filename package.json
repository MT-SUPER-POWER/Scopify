{
  "name": "scopify",
  "version": "1.0.1",
  "private": true,
  "author": {
    "name": "Momo",
    "email": "shuhengwen@gmail.com"
  },
  "contributors": [
    {
      "name": "TrimiTroll",
      "email": "1740627301@qq.com"
    }
  ],
  "homepage": "https://github.com/MT-SUPER-POWER",
  "type": "module",
  "main": "out/main/main.js",
  "description": "Electron + Next.js Music Player Base on NetEase Music API",
  "scripts": {
    "predev": "npx swc main -d out --out-file-extension js && node script/build-electron.cjs",
    "dev": "concurrently -n \"NEXT,ELECTRON\" -c \"yellow,blue\" --kill-others \"next dev\" \"electron .\" ",
    "backend": "node backend/api-enhanced/app.js",
    "web": "concurrently -n \"NEXT,NETEASE\" -c \"yellow,red\" --kill-others \"next dev\" \"npm run backend\" ",
    "build:web": "next build",
    "build:win": "next build && npx swc main -d out --out-file-extension js && node script/build-electron.cjs && electron-builder -- win",
    "afterbuild:win": "hello"
  },
  "dependencies": {
    "@applemusic-like-lyrics/core": "^0.2.0",
    "@applemusic-like-lyrics/lyric": "^0.3.0",
    "@applemusic-like-lyrics/react": "^0.2.0",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tabler/icons-react": "^3.38.0",
    "@tanstack/react-virtual": "^3.13.22",
    "axios": "^1.13.6",
    "colorthief": "^3.3.1",
    "electron-log": "^5.4.3",
    "electron-serve": "^3.0.1",
    "js-yaml": "^4.1.1",
    "jss": "^10.10.0",
    "jss-preset-default": "^10.10.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.34.4",
    "next": "16.1.6",
    "picocolors": "1.1.1",
    "radix-ui": "^1.4.3",
    "react-resizable-panels": "^4",
    "sonner": "^2.0.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "latest",
    "@types/colorthief": "^2.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-split-pane": "^0.1.67",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "zustand-devtools": "^1.1.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "build": {
    "appId": "com.momo.scopify",
    "productName": "Scopify",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "config",
        "to": "config",
        "filter": [
          "**/*.yml"
        ]
      },
      {
        "from": "backend/api-enhanced",
        "to": "backend/api-enhanced",
        "filter": [
          "**/*",
          "!test",
          "!*.log",
          "!.github",
          "!.husky"
        ]
      },
      {
        "from": "backend/api-enhanced/node_modules",
        "to": "backend/api-enhanced/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "out/**/*",
      "renderer/**/*",
      "public/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "dir"
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/uninstall.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "trustedDependencies": [
    "electron",
    "electron-builder",
    "sharp",
    "unrs-resolver"
  ]
}
