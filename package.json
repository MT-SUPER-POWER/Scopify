{
  "name": "scopify",
  "version": "1.0.4",
  "private": true,
  "author": {
    "name": "Momo",
    "email": "shuhengwen@gmail.com"
  },
  "contributors": [
    {
      "name": "TrimiTroll",
      "email": "1740627301@qq.com"
    }
  ],
  "workspaces": [
    "backend/api-enhanced"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MT-SUPER-POWER/Scopify.git"
  },
  "type": "module",
  "main": "out/main/main.js",
  "description": "Electron + Next.js Music Player Base on NetEase Music API",
  "scripts": {
    "dev": "concurrently -n \"NEXT,ELECTRON\" -c \"yellow,blue\" --kill-others \"bun run script/dev-web.ts\" \"electron .\"",
    "start": "concurrently -n \"NEXT,NETEASE\" -c \"yellow,red\" --kill-others \"bunx serve renderer -p 4545\" \"bun run backend\"",
    "backend:dev": "bun run backend/api-enhanced/app.js",
    "backend": "bun run out/backend/app.js",
    "web": "concurrently -n \"NEXT,NETEASE\" -c \"yellow,red\" --kill-others \"bun run script/dev-web.ts\" \"bun run backend\"",
    "build:backend": "bun build backend/api-enhanced/app.js --target=node --outfile=out/backend/app.js",
    "build:web": "next build",
    "predev": "bun script/build-electron.ts",
    "build:win": "bun run build:backend && bun run build:web && bun script/build-electron.ts && electron-builder -- win",
    "build:mac": "bun run build:backend && bun run build:web && bun script/build-electron.ts && electron-builder -- mac"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "electron-log": "^5.4.3",
    "electron-serve": "^3.0.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "framer-motion": "^12.38.0",
    "@applemusic-like-lyrics/core": "^0.2.0",
    "@applemusic-like-lyrics/lyric": "^0.3.0",
    "@applemusic-like-lyrics/react": "^0.2.0",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@tabler/icons-react": "^3.38.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-virtual": "^3.13.22",
    "@types/bun": "latest",
    "@types/colorthief": "^2.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-split-pane": "^0.1.67",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colorthief": "^3.3.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jss": "^10.10.0",
    "jss-preset-default": "^10.10.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.34.4",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "picocolors": "1.1.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "react-resizable-panels": "^4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "zustand": "^5.0.11",
    "zustand-devtools": "^1.1.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "build": {
    "appId": "com.momo.scopify",
    "productName": "Scopify",
    "publish": [
      "github"
    ],
    "artifactName": "${productName}.Setup.v${version}.${platform}.${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "compression": "maximum",
    "extraResources": [
      {
        "from": "config",
        "to": "config",
        "filter": [
          "**/*.yml"
        ]
      },
      {
        "from": "out/backend",
        "to": "backend",
        "filter": [
          "app.js"
        ]
      },
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "out/main/**/*.js",
      "renderer/**/*",
      "public/**/*",
      "package.json",
      "!**/node_modules",
      "!**/*.map",
      "!backend/api-enhanced"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        "zip",
        "dmg"
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.music",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "trustedDependencies": [
    "electron",
    "electron-builder",
    "sharp",
    "unrs-resolver"
  ]
}
