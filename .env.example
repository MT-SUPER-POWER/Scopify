# ==========================================
# Scopify Docker Compose & Environment Config
# ==========================================

# --- Backend Configuration ---
# The container name for the backend netease API service
BACKEND_CONTAINER_NAME=scopify-netease-api

# The port exposed by the backend container to the host
BACKEND_PORT=3838

# --- Frontend Configuration ---
# The container name for the Next.js web service
FRONTEND_CONTAINER_NAME=scopify-web

# The port exposed by the frontend container to the host
FRONTEND_PORT=3000

# --- Public API Endpoint (Used by the browser client) ---
# When accessing from a browser, the frontend needs to know where the backend API is.
# By default, it connects to http://127.0.0.1:3838
BACKEND_PUBLIC_HOST=127.0.0.1
BACKEND_PUBLIC_PORT=3838

# --- CORS Settings ---
# By default, if CORS_ALLOW_ORIGIN is empty, the backend automatically
# allows the request origin (dynamically mirrors the requester's Origin).
# This perfectly solves CORS issues for both Electron (app://-) and any Web deployment domain.
# If you want to restrict it or force a specific origin, you can set it below:
CORS_ALLOW_ORIGIN=
