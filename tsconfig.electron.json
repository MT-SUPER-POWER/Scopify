{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "outDir": "./out",
    "rootDir": "./main",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": [
    "main/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
